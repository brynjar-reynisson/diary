SESSION_SECRET=change-me-to-a-random-string

# ── App URL ────────────────────────────────────────────────────────────────────
# The public-facing base URL of this server (no trailing slash).
# Update GOOGLE_REDIRECT_URI and DROPBOX_REDIRECT_URI to match whenever you change this.
#
# dev:  APP_URL=http://localhost:3001
# cert: APP_URL=https://your-staging-domain.com
# prod: APP_URL=https://your-production-domain.com
APP_URL=http://localhost:3001

# ── Port ───────────────────────────────────────────────────────────────────────
# dev:  PORT=3001
# cert: PORT=443
# prod: PORT=443  (or leave unset if behind a reverse proxy)
PORT=3001

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# dev:  GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# cert: GOOGLE_REDIRECT_URI=https://your-staging-domain.com/api/auth/google/callback
# prod: GOOGLE_REDIRECT_URI=https://your-production-domain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Dropbox OAuth ──────────────────────────────────────────────────────────────
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
# dev:  DROPBOX_REDIRECT_URI=http://localhost:3001/api/auth/dropbox/callback
# cert: DROPBOX_REDIRECT_URI=https://your-staging-domain.com/api/auth/dropbox/callback
# prod: DROPBOX_REDIRECT_URI=https://your-production-domain.com/api/auth/dropbox/callback
DROPBOX_REDIRECT_URI=http://localhost:3001/api/auth/dropbox/callback
