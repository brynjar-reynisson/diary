# Base URL of the backend API.
# In dev the Vite proxy rewrites /api calls so this can be left empty (same origin).
# In cert/prod set it to the backend's public URL.
#
# dev:  VITE_API_URL=
# cert: VITE_API_URL=https://your-staging-domain.com
# prod: VITE_API_URL=https://your-production-domain.com
VITE_API_URL=
